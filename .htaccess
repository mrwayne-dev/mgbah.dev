# mgbah.dev — Apache Config
Options -Indexes

RewriteEngine On
RewriteBase /

# -----------------------------------------------------------------------
# Template preview — clean URL for standalone template HTML files
# -----------------------------------------------------------------------
RewriteRule ^templates/([a-z0-9-]+)/preview$ /api/template-view.php?slug=$1 [QSA,L]

# -----------------------------------------------------------------------
# Standalone pages, clean URLs for HTML files in assets/js/pages/
# -----------------------------------------------------------------------
RewriteRule ^wayne-tactic/?$ /assets/js/pages/wayne-tactic.html [L]
RewriteRule ^gameplan/?$ /assets/js/pages/gameplan.html [L]

# -----------------------------------------------------------------------
# SPA Routing — route all non-file, non-directory requests to index.php
# -----------------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# -----------------------------------------------------------------------
# PHP Access Control
# Block direct access to all .php files by default
# Only allow: index.php (root) and api/contact.php
# -----------------------------------------------------------------------
<FilesMatch "\.php$">
  Order Deny,Allow
  Deny from all
</FilesMatch>

<FilesMatch "^(index|contact|chat|template-view)\.php$">
  Order Allow,Deny
  Allow from all
</FilesMatch>

# -----------------------------------------------------------------------
# Sensitive File Protection
# -----------------------------------------------------------------------
<FilesMatch "^\.(env|gitignore|htaccess|gitattributes)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# Block vendor directory
<IfModule mod_rewrite.c>
  RewriteRule ^vendor/ - [F,L]
</IfModule>

# Block plans directory
<IfModule mod_rewrite.c>
  RewriteRule ^plans/ - [F,L]
</IfModule>

# -----------------------------------------------------------------------
# Security Headers
# -----------------------------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# -----------------------------------------------------------------------
# Gzip Compression
# -----------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE font/woff2
  AddOutputFilterByType DEFLATE font/woff
</IfModule>

# -----------------------------------------------------------------------
# Cache Static Assets
# -----------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp           "access plus 1 year"
  ExpiresByType image/svg+xml        "access plus 1 year"
  ExpiresByType image/png            "access plus 1 year"
  ExpiresByType image/jpeg           "access plus 1 year"
  ExpiresByType image/gif            "access plus 1 year"
  ExpiresByType font/woff2           "access plus 1 year"
  ExpiresByType text/css             "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# HTML — always revalidate (assets are cache-busted via ?v= query string)
<IfModule mod_headers.c>
  <FilesMatch "\.php$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
